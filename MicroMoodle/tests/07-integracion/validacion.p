# Test validacion: combina multiples sentencias y operadores
x := 10;
y := 3;
# Aritmeticos
s := x + y;
r := x - y;
m := x * y;
d := x / y;
di := x // y;
mod := x mod y;
print s;
print r;
print m;
print d;
print di;
print mod;
# Relacionales
print x > y;
print x <= y;
print x = 10;
print x <> 5;
# Logicos
print (x > 5) and (y < 5);
print (x > 5) or (y > 5);
print not (x = y);
