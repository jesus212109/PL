# Generic makefile for Flex exercises
#
# Usage:
#   make              -> builds analizador_lexico.exe (default)
#   make NAME=other   -> builds other.exe from other.l
#   make clean        -> removes generated object and intermediate files

NAME = analizador_lexico

# -----------------------------------------------------------------------
# Compiler flags
#   -c   : compile to object file only (no linking)
#   -g   : include debug symbols
#   -Wall: enable all warnings
#   -ansi: enforce ANSI C standard
#   -O2  : optimisation level 2
#   Suppressed warnings legitimately generated by flex output:
#   -Wno-unused-function -Wno-sign-compare -Wno-implicit-function-declaration
# -----------------------------------------------------------------------
CFLAGS = -c -g -Wall -ansi -O2 \
         -Wno-unused-function -Wno-sign-compare -Wno-implicit-function-declaration

# Flex runtime library
LFLAGS = -lfl

# -----------------------------------------------------------------------
# Predefined make macros:
#   $@  : target name
#   $^  : all prerequisites
#   $<  : first prerequisite
# -----------------------------------------------------------------------

## Link step
$(NAME).exe: $(NAME).o
	@echo "Linking $<  ->  $@"
	@gcc $< $(LFLAGS) -o $@

## Compile step
$(NAME).o: lex.yy.c
	@echo "Compiling lex.yy.c  ->  $@"
	@gcc $(CFLAGS) $< -o $@
	@echo "--> Removing auxiliary file: lex.yy.c"
	@rm -f lex.yy.c

## Flex step
lex.yy.c: $(NAME).l
	@echo "Running flex on $<"
	@flex $<

## Clean
.PHONY: clean
clean:
	@echo "--> Cleaning generated files"
	@rm -f lex.yy.c *.o *.exe
